<Page x:Class="Perm_Dynamics.Pages.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Perm_Dynamics.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="410" d:DesignWidth="782"
      Title="Main">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="53*"/>
            <ColumnDefinition Width="34*"/>
        </Grid.ColumnDefinitions>
        <Grid.Background>
            <ImageBrush ImageSource="/Images/Graph.jpg"/>
        </Grid.Background>
        <Label Content="PermDynamics" HorizontalAlignment="Center" Margin="113, 279, 103, 73" VerticalAlignment="Center"
               Foreground="White" FontSize="36" FontWeight="Bold"/>
        <Image HorizontalAlignment="Left" Height="100" Margin="113,186,0,0" VerticalAlignment="Top" Width="100"
               Source="/Images/icon-white.png" />
        <Label Content="Укажите начальное значение акции:" Grid.Column="1" Margin="12, 191, 82, 193"
               VerticalAlignment="Center" Foreground="White" Height="26" HorizontalAlignment="Center"/>
        <TextBox x:Name="tbValue" Grid.Column="1" Height="25" Margin="12, 217, 10, 168" VerticalContentAlignment="Center"
                 TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" Width="283"/>
        <Button Click="OpenPageChart" Content="Продолжить" Grid.Column="1" HorizontalAlignment="Center"
                Margin="195, 247, 10, 138" VerticalAlignment="Center" Width="100" Height="25" Background="White" BorderBrush="Black"/>
    </Grid>
</Page>